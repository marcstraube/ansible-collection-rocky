# =============================================================================
# Rocky Linux {{ rocky_version }} Kickstart Configuration
# =============================================================================
# Generated by Ansible (marcstraube.rocky.installer)
# Host: {{ inventory_hostname }}
# =============================================================================

# =============================================================================
# INSTALL SOURCE
# =============================================================================
url --mirrorlist="https://mirrors.rockylinux.org/mirrorlist?arch=x86_64&repo=BaseOS-{{ rocky_version }}&release={{ rocky_release }}"{% if rocky_proxy | length > 0 %} --proxy="{{ rocky_proxy }}"{% endif %}

repo --name="AppStream" --mirrorlist="https://mirrors.rockylinux.org/mirrorlist?arch=x86_64&repo=AppStream-{{ rocky_version }}&release={{ rocky_release }}"{% if rocky_proxy | length > 0 %} --proxy="{{ rocky_proxy }}"{% endif %}

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
text
skipx
firstboot --disable
eula --agreed
reboot

# =============================================================================
# LOCALE
# =============================================================================
lang {{ rocky_locale }}
keyboard --xlayouts='{{ rocky_keyboard }}'
timezone {{ rocky_timezone }} --utc

# =============================================================================
# NETWORK
# =============================================================================
{% if rocky_kickstart_network.method == 'static' %}
network --bootproto=static --device={{ rocky_kickstart_network.device }} --ip={{ rocky_kickstart_network.ip }} --netmask={{ rocky_kickstart_network.netmask }}{% if rocky_kickstart_network.gateway | default('') | length > 0 %} --gateway={{ rocky_kickstart_network.gateway }}{% endif %} --nameserver={{ rocky_kickstart_network.nameserver }} --hostname={{ rocky_kickstart_network.hostname }} --activate
{% else %}
network --bootproto=dhcp --device={{ rocky_kickstart_network.device }} --hostname={{ rocky_kickstart_network.hostname }} --activate
{% endif %}

# =============================================================================
# SECURITY
# =============================================================================
rootpw --iscrypted {{ __rocky_root_password_hash }}
firewall --enabled --service={{ rocky_kickstart_firewall_services | join(',') }}
selinux --{{ rocky_selinux }}

# =============================================================================
# BOOTLOADER
# =============================================================================
bootloader --location=mbr --boot-drive={{ rocky_disk.device }}

# =============================================================================
# DISK PARTITIONING
# =============================================================================
zerombr
clearpart --all --initlabel --drives={{ rocky_disk.device }}

{% if rocky_disk.method == 'lvm' %}
# LVM partitioning
part /boot --fstype=xfs --size=1024 --ondisk={{ rocky_disk.device }}
part /boot/efi --fstype=efi --size=512 --ondisk={{ rocky_disk.device }}
part pv.01 --size=1 --grow --ondisk={{ rocky_disk.device }}

volgroup {{ rocky_disk.vg_name }} pv.01

logvol swap --fstype=swap --name=lv_swap --vgname={{ rocky_disk.vg_name }} --size={{ rocky_disk.lv_swap_size }}
{% if rocky_disk.lv_root_size > 0 %}
logvol / --fstype=xfs --name=lv_root --vgname={{ rocky_disk.vg_name }} --size={{ rocky_disk.lv_root_size }}
{% else %}
logvol / --fstype=xfs --name=lv_root --vgname={{ rocky_disk.vg_name }} --size=1 --grow
{% endif %}
{% else %}
# Automatic partitioning
autopart --type=lvm --fstype=xfs
{% endif %}

# =============================================================================
# PACKAGES
# =============================================================================
%packages
{{ rocky_package_group }}
{% for pkg in rocky_additional_packages %}
{{ pkg }}
{% endfor %}
%end

# =============================================================================
# POST-INSTALL SCRIPT
# =============================================================================
%post --log=/root/ks-post.log

# Enable SSH service
systemctl enable sshd

# Create admin user with wheel group
useradd -m -s /bin/bash -G wheel {{ rocky_admin_user }}
echo "{{ rocky_admin_user }} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/{{ rocky_admin_user }}
chmod 440 /etc/sudoers.d/{{ rocky_admin_user }}
{% if rocky_admin_ssh_key | length > 0 %}

# Configure SSH key for admin user
mkdir -p /home/{{ rocky_admin_user }}/.ssh
chmod 700 /home/{{ rocky_admin_user }}/.ssh
echo "{{ rocky_admin_ssh_key }}" > /home/{{ rocky_admin_user }}/.ssh/authorized_keys
chmod 600 /home/{{ rocky_admin_user }}/.ssh/authorized_keys
chown -R {{ rocky_admin_user }}:{{ rocky_admin_user }} /home/{{ rocky_admin_user }}/.ssh
restorecon -R /home/{{ rocky_admin_user }}/.ssh
{% endif %}
{% if rocky_kickstart_network_secondary is defined and rocky_kickstart_network_secondary.ip | default('') | length > 0 %}

# Configure secondary IP address
nmcli connection modify {{ rocky_kickstart_network.device }} +ipv4.addresses "{{ rocky_kickstart_network_secondary.ip }}/{{ rocky_kickstart_network_secondary.prefix | default(24) }}"
{% endif %}
{% if rocky_proxy | length > 0 %}

# Configure proxy for dnf
echo "proxy={{ rocky_proxy }}" >> /etc/dnf/dnf.conf
{% endif %}

# Disable root SSH login
sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config

%end
